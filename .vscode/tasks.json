{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure (Debug)",
      "type": "shell",
      "command": "cmake --preset debug",
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Configure (Release)",
      "type": "shell",
      "command": "cmake --preset release",
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build (Debug)",
      "type": "shell",
      "command": "cmake --build --preset debug",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "Configure (Debug)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Build (Release)",
      "type": "shell",
      "command": "cmake --build --preset release",
      "group": "build",
      "dependsOn": "Configure (Release)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Test (Debug)",
      "type": "shell",
      "command": "ctest --preset debug --output-on-failure",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "dependsOn": "Build (Debug)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run hello_triangle",
      "type": "shell",
      "command": "${workspaceFolder}/build/debug/tools/hello_triangle",
      "dependsOn": "Build (Debug)",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
