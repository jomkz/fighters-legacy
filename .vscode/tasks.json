{
  "version": "2.0.0",
  "tasks": [
    // ── Build ──────────────────────────────────────────────────────────────
    {
      "label": "Configure (Debug)",
      "type": "shell",
      "command": "cmake --preset debug -DFETCHCONTENT_QUIET=OFF",
      "windows": {
        "options": {
          "shell": { "executable": "powershell.exe", "args": ["-NoProfile", "-Command"] }
        },
        "command": "$vs = & 'C:/Program Files (x86)/Microsoft Visual Studio/Installer/vswhere.exe' -latest -property installationPath; & \"$vs/Common7/Tools/Launch-VsDevShell.ps1\" -Arch amd64 -SkipAutomaticLocation; cmake --preset debug-msvc -DFETCHCONTENT_QUIET=OFF"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Configure (Release)",
      "type": "shell",
      "command": "cmake --preset release -DFETCHCONTENT_QUIET=OFF",
      "windows": {
        "options": {
          "shell": { "executable": "powershell.exe", "args": ["-NoProfile", "-Command"] }
        },
        "command": "$vs = & 'C:/Program Files (x86)/Microsoft Visual Studio/Installer/vswhere.exe' -latest -property installationPath; & \"$vs/Common7/Tools/Launch-VsDevShell.ps1\" -Arch amd64 -SkipAutomaticLocation; cmake --preset release-msvc -DFETCHCONTENT_QUIET=OFF"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build (Debug)",
      "type": "shell",
      "command": "cmake --build --preset debug",
      "windows": {
        "options": {
          "shell": { "executable": "powershell.exe", "args": ["-NoProfile", "-Command"] }
        },
        "command": "$vs = & 'C:/Program Files (x86)/Microsoft Visual Studio/Installer/vswhere.exe' -latest -property installationPath; & \"$vs/Common7/Tools/Launch-VsDevShell.ps1\" -Arch amd64 -SkipAutomaticLocation; cmake --build --preset debug-msvc"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "Configure (Debug)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$gcc", "$msCompile"]
    },
    {
      "label": "Build (Release)",
      "type": "shell",
      "command": "cmake --build --preset release",
      "windows": {
        "options": {
          "shell": { "executable": "powershell.exe", "args": ["-NoProfile", "-Command"] }
        },
        "command": "$vs = & 'C:/Program Files (x86)/Microsoft Visual Studio/Installer/vswhere.exe' -latest -property installationPath; & \"$vs/Common7/Tools/Launch-VsDevShell.ps1\" -Arch amd64 -SkipAutomaticLocation; cmake --build --preset release-msvc"
      },
      "group": "build",
      "dependsOn": "Configure (Release)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$gcc", "$msCompile"]
    },

    // ── Test ───────────────────────────────────────────────────────────────
    {
      "label": "Test (Debug)",
      "type": "shell",
      "command": "ctest --preset debug --output-on-failure",
      "windows": {
        "command": "ctest --preset debug-msvc --output-on-failure"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "dependsOn": "Build (Debug)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },

    {
      "label": "Coverage (engine/ branch summary)",
      "type": "shell",
      "command": "cmake --preset coverage && cmake --build --preset coverage && cd build/coverage && ctest --output-on-failure && gcovr --filter '../../engine/' --gcov-ignore-errors all --gcov-ignore-parse-errors suspicious_hits.warn_once_per_file --exclude-throw-branches --fail-under-branch 80 --print-summary",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // ── CI checks (Linux) ──────────────────────────────────────────────────
    //
    // "CI: All (Linux)" runs every check below in sequence.
    // Individual tasks can also be run standalone from the command palette.
    // ASAN, coverage, clang-format, and REUSE are Linux/macOS only.
    {
      "label": "CI: clang-format check",
      "type": "shell",
      "command": "git diff --name-only --diff-filter=d origin/main...HEAD | grep -E '\\.(cpp|h|hpp|c)$' | xargs -r clang-format-22 --dry-run --Werror",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: REUSE lint",
      "type": "shell",
      "command": "reuse lint",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: Smoke tests",
      "type": "shell",
      "command": "./build/debug/game/fighters-legacy/fighters-legacy --version && ./build/debug/server/fl-server/fl-server --version && ./build/debug/tools/validate-flight-model --version && ./build/debug/tools/validate-mission --version && ./build/debug/tools/validate-mesh --version && python3 tools/gen_builtin_glb.py --export-dir /tmp/builtin-meshes && mesh_out=$(./build/debug/tools/validate-mesh /tmp/builtin-meshes/builtin_entity.glb /tmp/builtin-meshes/builtin_floor.glb 2>&1) && test -z \"$mesh_out\" && ./build/debug/tools/tex-compress --version && ./build/debug/tools/validate-licenses --version && ./build/debug/tools/validate-playlist --version && ./build/debug/tools/terrain-chunk-io --version && ./build/debug/server/fl-server/fl-server 7002 1 & FL_SERVER_PID=$!; sleep 10; ./build/debug/tools/net_check 127.0.0.1 7002 --count 3 --interval 100; kill \"$FL_SERVER_PID\" 2>/dev/null || true; bash tools/bot_swarm/run_loadtest.sh build/debug 8 3 weave",
      "dependsOn": "Build (Debug)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: pytest (gen_terrain_chunks)",
      "type": "shell",
      "command": "python3 -m pytest tests/test_gen_terrain_chunks.py -v",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: pytest (latency_compare)",
      "type": "shell",
      "command": "python3 -m pytest tests/test_latency_compare.py -v",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: pytest (scale_gate)",
      "type": "shell",
      "command": "python3 -m pytest tests/test_scale_gate.py -v",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: Scale gate (PR)",
      "type": "shell",
      "command": "cmake --preset release -DCMAKE_DISABLE_FIND_PACKAGE_Vulkan=ON && cmake --build --preset release --target fl-server bot_swarm && python3 tools/bot_swarm/scale_gate.py --profile pr --build-dir build/release --baseline tools/bot_swarm/scale-gate-baseline.json",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: Locale lint",
      "type": "shell",
      "command": "cmake --build --preset debug --target locale-extract && ./build/debug/tools/locale-extract --src engine --locale locale --dry-run",
      "dependsOn": "Build (Debug)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: Configure (ASAN)",
      "type": "shell",
      "command": "cmake --preset asan -DFETCHCONTENT_QUIET=OFF",
      "env": {
        "CC": "clang",
        "CXX": "clang++"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: Build (ASAN)",
      "type": "shell",
      "command": "cmake --build --preset asan",
      "group": "build",
      "dependsOn": "CI: Configure (ASAN)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "CI: Test (ASAN)",
      "type": "shell",
      "command": "mkdir -p \"$HOME/.config\" && printf '[general]\\ndrivers = null\\n' > \"$HOME/.config/alsoft.conf\" && ctest --preset asan --output-on-failure",
      "env": {
        "ASAN_OPTIONS": "halt_on_error=1:detect_leaks=1",
        "UBSAN_OPTIONS": "halt_on_error=1:print_stacktrace=1"
      },
      "group": "test",
      "dependsOn": "CI: Build (ASAN)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: Configure (TSAN)",
      "type": "shell",
      "command": "cmake --preset tsan -DFETCHCONTENT_QUIET=OFF",
      "env": {
        "CC": "clang",
        "CXX": "clang++"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: Build (TSAN)",
      "type": "shell",
      "command": "cmake --build --preset tsan --target test_job_system test_world_broadcaster",
      "group": "build",
      "dependsOn": "CI: Configure (TSAN)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "CI: Test (TSAN)",
      "type": "shell",
      "command": "TSAN_OPTIONS=\"suppressions=$PWD/tools/tsan.supp\" ./build/tsan/tests/test_job_system && TSAN_OPTIONS=\"suppressions=$PWD/tools/tsan.supp\" ./build/tsan/tests/test_world_broadcaster",
      "group": "test",
      "dependsOn": "CI: Build (TSAN)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: All (Linux)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "CI: clang-format check",
        "CI: REUSE lint",
        "Build (Debug)",
        "CI: Smoke tests",
        "CI: pytest (gen_terrain_chunks)",
        "CI: pytest (latency_compare)",
        "CI: pytest (scale_gate)",
        "CI: Locale lint",
        "CI: Test (ASAN)"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },

    // ── CI checks (Windows) ────────────────────────────────────────────────
    //
    // Mirrors the windows-latest CI steps. ASAN, coverage, clang-format,
    // REUSE, and Python tool tests are Linux-only and excluded here.
    {
      "label": "CI: Smoke tests (Windows)",
      "type": "shell",
      "options": {
        "shell": { "executable": "powershell.exe", "args": ["-NoProfile", "-Command"] }
      },
      "command": ".\\build\\debug-msvc\\game\\fighters-legacy\\fighters-legacy.exe --version; .\\build\\debug-msvc\\server\\fl-server\\fl-server.exe --version; .\\build\\debug-msvc\\tools\\validate-flight-model.exe --version; .\\build\\debug-msvc\\tools\\validate-mission.exe --version; .\\build\\debug-msvc\\tools\\validate-mesh.exe --version; .\\build\\debug-msvc\\tools\\tex-compress.exe --version; .\\build\\debug-msvc\\tools\\validate-licenses.exe --version; .\\build\\debug-msvc\\tools\\validate-playlist.exe --version; .\\build\\debug-msvc\\tools\\terrain-chunk-io.exe --version",
      "dependsOn": "Build (Debug)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CI: All (Windows)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Build (Debug)",
        "Test (Debug)",
        "CI: Smoke tests (Windows)"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
